# ---- App ----
# UTC offset (hours) of the cameras' location (dacha local time).
# Moscow=3, Magadan=11. Used for the schedule and message timestamps.
APP_UTC_OFFSET=3
APP_LOG_LEVEL=INFO

# ---- Telegram ----
TG_TOKEN=123456:your-bot-token
# The group the bot is bound to: it posts all alerts there and only accepts
# commands from this chat. Anyone in the group can control the bot. Supergroup
# ids are negative, e.g. -1001234567890.
TG_CHAT_ID=-1001234567890
# SOCKS5/HTTP proxy for ALL Telegram traffic. Telegram is unreachable without it.
# e.g. socks5://user:pass@host:1080  or  http://user:pass@host:8080
TG_PROXY_URL=socks5://user:pass@proxyhost:1080

# ---- Postgres (in compose) ----
DB_HOST=postgres
DB_PORT=5432
DB_USER=alert
DB_PASSWORD=alert
DB_NAME=alert

# ---- MQTT (RabbitMQ MQTT plugin) ----
MQTT_HOST=mqtt.rabbitmq.example.com
MQTT_PORT=8883
MQTT_TLS=true
MQTT_USER=botuser
MQTT_PASSWORD=botpass
MQTT_TOPIC=frigate/reviews
MQTT_CLIENT_ID=dacha-alert-bot

# ---- AMQP (same RabbitMQ, native protocol, internal work queues) ----
AMQP_HOST=rabbitmq.example.com
# With TLS on RabbitMQ use the amqps listener (usually 5671) and AMQP_TLS=true.
AMQP_PORT=5671
AMQP_TLS=true
AMQP_USER=botuser
AMQP_PASSWORD=botpass
AMQP_VHOST=/

# ---- Frigate ----
FRIGATE_URL=https://frigate.example.com
FRIGATE_USER=bot
FRIGATE_PASSWORD=frigate-bot-pass
# Snapshot quality/height passed to Frigate's snapshot API. Frigate only decodes
# the DETECT stream, so the real resolution ceiling is the detect stream — for
# sharper photos raise the detect resolution in Frigate's own config. These just
# avoid the API's default down-scale (height=175) / recompress (quality=60).
# height is capped at the detect stream's native height; set 0 to omit a param.
FRIGATE_SNAPSHOT_QUALITY=95
FRIGATE_SNAPSHOT_HEIGHT=1080

# ---- MinIO ----
MINIO_ENDPOINT=minio.example.com:443
MINIO_KEY=minio-access-key
MINIO_SECRET=minio-secret-key
MINIO_BUCKET=dacha-events
MINIO_SECURE=true
MINIO_PRESIGN_TTL=604800
